msgstr "Получатели"

msgid "Optional email summary of scheduled, missed, and upcoming posts."
msgstr "Необязательная email-сводка запланированных, пропущенных и предстоящих записей."

msgid "Maximum number of scheduled items shown in the widget."
msgstr "Максимальное количество запланированных элементов в виджете."

msgid "Select which post types to include in the widget."
msgstr "Выберите, какие типы записей включать в виджет."

msgid "Show drafts alongside scheduled posts in their own group."
msgstr "Показывать черновики рядом с запланированными записями в отдельной группе."

msgid "List"
msgstr "Список"

msgid "Each user can override their view from the widget."
msgstr "Каждый пользователь может изменить свой вид из виджета."

msgid "Automatically publish scheduled posts WordPress failed to publish on time."
msgstr "Автоматически публиковать запланированные записи, которые WordPress не смог опубликовать вовремя."

msgid "Send an email summary on a schedule."
msgstr "Отправлять email-сводку по расписанию."

msgid "Daily"
msgstr "Ежедневно"

msgid "Weekly"
msgstr "Еженедельно"

msgid "One or more emails, comma or newline separated. Defaults to the site admin email if empty."
msgstr "Один или несколько email-адресов через запятую или перенос строки. По умолчанию — email администратора сайта."

msgid "No scheduled content found."
msgstr "Запланированного контента не найдено."

